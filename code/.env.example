# Environment Variables for Multi-Modal Evidence Review System
# Copy this file to .env and fill in your API keys.
# The pipeline runs in mock mode if keys are absent — no keys required to produce output.csv.

# Anthropic API key — required for Claude 3.5 Sonnet / Haiku
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API key — required for Gemini 1.5 Pro / Flash
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-key-here

# Optional: Override the local Ollama/vLLM endpoint for open-source VLMs
# Default: http://localhost:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
